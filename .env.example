# ────────────────────────────────────────────────────────────
# Sleepcomet Landing Page — Arquivo de Exemplo de Variáveis de Ambiente
# Renomeie para .env ou .env.local e preencha com os dados reais
# ────────────────────────────────────────────────────────────

# URL do Web App / Dashboard do Sleepcomet (para onde os botões de login/começar direcionam)
NEXT_PUBLIC_APP_URL=http://localhost:5173

# URL oficial deste site institucional (Landing Page)
NEXT_PUBLIC_SITE_URL=https://sleepcomet.com

# URL do servidor Discord da comunidade
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/sleepcomet

# Analytics (PostHog Token de rastreamento)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_seu_token_posthog_aqui

# Integração de Suporte em tempo real (Chatwoot)
NEXT_PUBLIC_CHATWOOT_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=seu_website_token_do_chatwoot

# Otimização e SEO (Opcionais)
NEXT_PUBLIC_GOOGLE_VERIFICATION=google_verification_code_aqui
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=meta_pixel_id_aqui
